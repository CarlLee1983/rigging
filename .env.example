# Required environment variables
# Copy this file to .env and fill in your values

DATABASE_URL=postgresql://rigging:rigging@localhost:5432/rigging
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Email delivery (optional — leave unset to use ConsoleEmailAdapter for local dev)
# Set both to enable Resend-backed email in production
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Redis URL for rate limiting and session storage (optional, falls back to memory if unset)
REDIS_URL=redis://localhost:6379

# OpenTelemetry (optional)
# Set to your OTLP collector endpoint to enable trace export.
# Leave unset for no-op (no spans exported).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
