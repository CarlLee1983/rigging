# Rigging - local development environment variables.
# Copy this file to .env.local and fill in real values.
# DO NOT commit .env.local. The `.gitignore` keeps all .env* except .env.example.

# Database (matches docker-compose.yml dev credentials - dev-only, DO NOT reuse in production)
DATABASE_URL=postgresql://rigging:rigging_dev_password@localhost:5432/rigging

# BetterAuth (Phase 3 will consume; P1 validates presence at startup)
# Generate with: openssl rand -hex 32  (or: bun eval 'console.log(crypto.randomUUID().replaceAll("-", "") + crypto.randomUUID().replaceAll("-", ""))')
# Must be at least 32 characters. PLACEHOLDER below - replace before running.
BETTER_AUTH_SECRET=change-me-to-32-byte-random-hex-before-committing
BETTER_AUTH_URL=http://localhost:3000

# HTTP server
PORT=3000

# Runtime mode: development | production | test
NODE_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=debug
